# Plantilla de variables de entorno — copiar a `.env.local` (recomendado) o `.env`.
# Los valores aquí son orientativos; en producción usar secretos fuertes y gestión segura (vault, secrets del hosting).
# Documentación: README.md «Variables de entorno y despliegue».

###> symfony/framework-bundle ###
# Entorno de Symfony: en producción usar `prod` (nunca commitear credenciales reales).
APP_ENV=dev
APP_DEBUG=1
# Secreto único por entorno. Sirve para cookies CSRF, remember_me y firma JWT de la API (HS256).
# Generar uno nuevo al desplegar; rotar invalida sesiones y tokens JWT emitidos con el secreto anterior.
# Ejemplo: openssl rand -hex 32
APP_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# MySQL/MariaDB típico (ajustar usuario, contraseña, host, nombre BD).
# En SQLite de pruebas PHPUnit suele definirse en `.env.test`, no aquí.
DATABASE_URL="mysql://app:app@127.0.0.1:3306/constructora?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# Transporte SMTP u otro compatible con Symfony Mailer (ver documentación Mailer).
MAILER_DSN=null://null
###< symfony/mailer ###

###> correo y presupuestos (config/services.yaml) ###
MAILER_SENDER_ADDRESS=noreply@example.com
MAILER_FROM_NAME=Constructora
# Envío de presupuestos (DSN dedicado + cabeceras).
MAILER_QUOTES_DSN=null://null
MAILER_QUOTES_SENDER_ADDRESS=quotes@example.com
MAILER_QUOTES_FROM_NAME=Quotes
MAILER_QUOTES_COPY_ADDRESS=
###< correo y presupuestos ###

###> google / integraciones ###
GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET=
GOOGLE_MAPS_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
###< google / integraciones ###

###> firebase (push FCM) ###
# Ruta al JSON de cuenta de servicio (relativa al directorio del proyecto o absoluta). Ver README.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=firebase-service-account.json
###< firebase ###

###> aplicación ###
# URL base pública del sitio (según entorno).
direccion_url=https://localhost
QUICKBOOK_ACCOUNT_NAME=
###< aplicación ###

###> symfony/lock (rate limiting API, etc.) ###
# Ejemplos: semaphore | flock:///tmp/constructora-lock | redis://localhost
LOCK_DSN=flock:///tmp/constructora-lock
###< symfony/lock ###

###> symfony/messenger ###
# Cola async (Doctrine es habitual si ya usas la misma BD). Si no usas workers, igual debe ser válido para arrancar el kernel.
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=messenger
###< symfony/messenger ###

###> symfony/var-dumper (solo dev; when@dev en config/packages/debug.yaml) ###
VAR_DUMPER_SERVER=127.0.0.1:9912
###< symfony/var-dumper ###
