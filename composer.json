{
   "type": "project",
   "license": "proprietary",
   "minimum-stability": "stable",
   "prefer-stable": true,
   "require": {
      "php": ">=8.2",
      "ext-ctype": "*",
      "ext-iconv": "*",
      "doctrine/dbal": "^3",
      "doctrine/doctrine-bundle": "^2.14",
      "doctrine/doctrine-migrations-bundle": "^3.4",
      "doctrine/instantiator": "^2.0 <2.1",
      "doctrine/orm": "^3.4.1 <3.5",
      "eskrano/quickbooks-php-8": "^0.1.2",
      "firebase/php-jwt": "*",
      "google/cloud-translate": "*",
      "mpdf/mpdf": "^8.2",
      "nelmio/api-doc-bundle": "*",
      "nelmio/cors-bundle": "^2.5",
      "phpoffice/phpspreadsheet": "^4.1",
      "symfony/asset": "7.2.*",
      "symfony/asset-mapper": "7.2.*",
      "symfony/console": "7.2.*",
      "symfony/doctrine-messenger": "7.2.*",
      "symfony/dotenv": "7.2.*",
      "symfony/expression-language": "7.2.*",
      "symfony/flex": "^2",
      "symfony/form": "7.2.*",
      "symfony/framework-bundle": "7.2.*",
      "symfony/http-client": "7.2.*",
      "symfony/intl": "7.2.*",
      "symfony/lock": "7.2.*",
      "symfony/mailer": "7.2.*",
      "symfony/messenger": "7.2.*",
      "symfony/mime": "7.2.*",
      "symfony/monolog-bundle": "^3.0",
      "symfony/notifier": "7.2.*",
      "symfony/polyfill-intl-messageformatter": "^1.31",
      "symfony/process": "7.2.*",
      "symfony/property-access": "7.2.*",
      "symfony/property-info": "7.2.*",
      "symfony/rate-limiter": "7.2.*",
      "symfony/requirements-checker": "^2.0",
      "symfony/runtime": "7.2.*",
      "symfony/security-bundle": "7.2.*",
      "symfony/serializer": "7.2.*",
      "symfony/stimulus-bundle": "^2.24",
      "symfony/string": "7.2.*",
      "symfony/translation": "7.2.*",
      "symfony/twig-bundle": "7.2.*",
      "symfony/ux-turbo": "^2.24",
      "symfony/validator": "7.2.*",
      "symfony/web-link": "7.2.*",
      "symfony/yaml": "7.2.*",
      "twig/extra-bundle": "^2.12|^3.0",
      "twig/intl-extra": "*",
      "twig/twig": "^2.12|^3.0"
   },
   "config": {
      "platform-check": false,
      "allow-plugins": {
         "php-http/discovery": true,
         "symfony/flex": true,
         "symfony/runtime": true
      },
      "bump-after-update": true,
      "sort-packages": true
   },
   "autoload": {
      "psr-4": {
         "App\\": "src/"
      },
      "files": [
         "vendor/phpqrcode/qrlib.php"
      ]
   },
   "autoload-dev": {
      "psr-4": {
         "App\\Tests\\": "tests/"
      }
   },
   "replace": {
      "symfony/polyfill-ctype": "*",
      "symfony/polyfill-iconv": "*",
      "symfony/polyfill-php72": "*",
      "symfony/polyfill-php73": "*",
      "symfony/polyfill-php74": "*",
      "symfony/polyfill-php80": "*",
      "symfony/polyfill-php81": "*",
      "symfony/polyfill-php82": "*"
   },
   "scripts": {
      "auto-scripts": {
         "cache:clear": "symfony-cmd",
         "assets:install %PUBLIC_DIR% --no-cleanup": "symfony-cmd",
         "importmap:install": "symfony-cmd",
         "requirements-checker": "script"
      },
      "phpstan": "bash scripts/phpstan.sh",
      "phpstan:full": "bash scripts/phpstan-full.sh",
      "cs-check": "@php vendor/bin/php-cs-fixer fix --dry-run --diff",
      "cs-fix": "@php vendor/bin/php-cs-fixer fix",
      "test": "@php vendor/bin/phpunit",
      "quality": [
         "@phpstan",
         "@test"
      ],
      "install-git-hooks": "git config core.hooksPath .githooks",
      "post-install-cmd": [
         "@auto-scripts"
      ],
      "post-update-cmd": [
         "@auto-scripts"
      ]
   },
   "conflict": {
      "symfony/symfony": "*"
   },
   "extra": {
      "symfony": {
         "allow-contrib": false,
         "require": "7.2.*"
      }
   },
   "require-dev": {
      "friendsofphp/php-cs-fixer": "*",
      "phpstan/phpstan": "*",
      "phpstan/phpstan-doctrine": "*",
      "phpstan/phpstan-symfony": "*",
      "phpunit/phpunit": "^9.5",
      "symfony/browser-kit": "7.2.*",
      "symfony/css-selector": "7.2.*",
      "symfony/debug-bundle": "7.2.*",
      "symfony/maker-bundle": "^1.0",
      "symfony/phpunit-bridge": "^7.2",
      "symfony/stopwatch": "7.2.*",
      "symfony/web-profiler-bundle": "7.2.*"
   }
}
