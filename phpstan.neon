# Análisis habitual: mismas reglas + baseline (solo ignoramos lo ya inventariado).
# PHPStan SIGUE analizando todo src/: cualquier error NUEVO o que cambie de sitio
# suele hacer fallar el análisis hasta actualizar código o el baseline.
#
# Ver TODOS los hallazgos sin ocultar deuda: composer phpstan:full

includes:
    - phpstan.base.neon
    - phpstan-baseline.neon
