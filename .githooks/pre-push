#!/usr/bin/env bash
# Hook de Git: antes de cada push → verificar estilo (PHP-CS-Fixer) + PHPStan.
# Activación (una vez por clon): composer install-git-hooks
#
# Formatear antes del commit (recomendado): composer quality:fix
# Verificar sin modificar archivos: composer quality
#
# Omitir solo en casos puntuales:
#   SKIP_PRE_PUSH=1 git push
#   git push --no-verify

set -euo pipefail

if [[ "${SKIP_PRE_PUSH:-}" == "1" ]]; then
   echo "SKIP_PRE_PUSH=1: se omite pre-push (quality)."
   exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# PHPStan (extensión Symfony) necesita el XML del contenedor en dev.
CONTAINER_XML="var/cache/dev/App_KernelDevDebugContainer.xml"
if [[ ! -f "${CONTAINER_XML}" ]]; then
   echo "pre-push: generando caché Symfony (dev) para PHPStan..."
   php bin/console cache:warmup --env=dev --no-ansi
fi

echo "pre-push: verificando estilo (PHP-CS-Fixer, dry-run)..."
if ! composer cs-check --no-interaction; then
   echo ""
   echo "pre-push: el código no cumple el estilo. Corrige y commitea:"
   echo "  composer cs-fix"
   echo "  git add -u && git commit -m 'style: PHP-CS-Fixer'"
   echo "Luego vuelve a hacer push."
   exit 1
fi

echo "pre-push: ejecutando PHPStan..."
composer phpstan --no-interaction

echo "pre-push: OK (cs-check + phpstan)."
exit 0
