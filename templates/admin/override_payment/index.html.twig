{% extends 'admin/layout.html.twig' %}
{% block subtitle %} - Override Payment{% endblock %}
{% block stylesheetspecific %}
<link href="{{ asset('bundles/metronic8/plugins/datatable/fixed-column/fixedColumns.bootstrap5.min.css') }}" rel="stylesheet" type="text/css" />
<style>
   .dtfc-fixed-start, .dtfc-fixed-end { background: #fff !important; }
</style>
{% endblock %}

{% block content %}
<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
   <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
      <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
         <h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">Override Payment</h1>
         <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
            <li class="breadcrumb-item text-muted">Accounting</li>
            <li class="breadcrumb-item"><span class="bullet bg-gray-500 w-5px h-2px"></span></li>
            <li class="breadcrumb-item text-muted">Override Payment</li>
         </ul>
      </div>
   </div>
</div>

<div id="kt_app_content" class="app-content flex-column-fluid">
   <div id="kt_app_content_container" class="app-container container-fluid">
      <div id="lista-override-payment" class="card card-sticky">
         <div class="card-header border-0 pt-6">
            <div class="card-title">
               <div class="d-flex align-items-center position-relative my-1">
                  <i class="ki-duotone ki-magnifier text-primary fs-3 position-absolute ms-5">
                     <span class="path1"></span><span class="path2"></span>
                  </i>
                  <input type="text" data-table-filter="search" class="form-control form-control-solid w-300px ps-13" placeholder="Search..." />
               </div>
            </div>
            <div class="card-toolbar">
               <div class="d-flex flex-wrap justify-content-end gap-2">
                  {% if permiso.agregar or permiso.editar %}
                  <button type="button" class="btn btn-success hide" id="btn-salvar-override-payment" title="Save paid qty overrides">
                     <i class="ki-duotone ki-save-2 fs-2"><span class="path1"></span><span class="path2"></span></i>
                     <span class="d-none d-md-inline ms-1">Save</span>
                  </button>
                  {% endif %}
                  <div>
                     <button type="button" class="btn btn-primary" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                        <i class="ki-duotone ki-filter fs-2"><span class="path1"></span><span class="path2"></span></i>
                        <span class="d-none d-md-inline">Filter</span>
                     </button>
                     <div class="menu menu-sub menu-sub-dropdown w-300px w-md-325px" data-kt-menu="true">
                        <div class="px-7 py-5">
                           <div class="fs-5 text-gray-900 fw-bold">Filter options</div>
                        </div>
                        <div class="separator border-gray-200"></div>
                        <div class="px-7 py-5">
                           <div class="mb-3">
                              <select id="filtro-company-op" class="form-select form-select2 form-select-solid fw-bold">
                                 <option value="">Company</option>
                                 {% for item in companies %}
                                 <option value="{{ item.companyId }}">{{ item.name }}</option>
                                 {% endfor %}
                              </select>
                           </div>
                           <div class="mb-3" id="select-filtro-project-op">
                              <select class="form-select form-select2 form-select-solid fw-bold" id="filtro-project-op">
                                 <option value="">Project</option>
                              </select>
                           </div>
                           <div class="mb-3">
                              <label class="form-label fs-7 text-gray-600 mb-1">Invoice end date</label>
                              <div class="input-group input-group-solid date-picker-filter" id="op-datetimepicker-fecha-fin" data-td-target-input="nearest" data-td-target-toggle="nearest">
                                 <input type="text" class="form-control filter-date" placeholder="m/d/Y" data-td-target="#op-datetimepicker-fecha-fin" autocomplete="off" />
                                 <span class="input-group-text" data-td-target="#op-datetimepicker-fecha-fin" data-td-toggle="datetimepicker">
                                    <i class="ki-duotone ki-calendar fs-2"><span class="path1"></span><span class="path2"></span></i>
                                 </span>
                              </div>
                              <div class="form-text">Totals include invoices with end date on or before this date.</div>
                           </div>
                           <div class="d-flex justify-content-end mt-10">
                              <button type="reset" class="btn btn-light btn-active-light-primary fw-semibold me-2 px-6" data-kt-menu-dismiss="true" id="btn-reset-filtrar-op">Reset filters</button>
                              <button type="button" class="btn btn-primary fw-semibold px-6" data-kt-menu-dismiss="true" id="btn-filtrar-op">Apply</button>
                           </div>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </div>
         <div class="card-body">
            <div id="override-payment-list-placeholder" class="text-center py-15 px-5">
               <i class="ki-duotone ki-filter-search text-primary fs-3x mb-5">
                  <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span>
               </i>
               <p class="text-gray-700 fw-semibold fs-4 mb-2">Apply a filter to view items</p>
               <p class="text-gray-500 fs-6 mb-0">Select <strong>Company</strong> and <strong>Project</strong> (required). Optionally set <strong>Invoice end date</strong> so totals use invoices ending on or before that date. Then click <strong>Apply</strong>. Use <strong>Save</strong> to persist paid qty overrides for the same filter.</p>
            </div>
            <div id="override-payment-table-wrapper" class="hide">
               <table id="override-payment-items-table" class="table table-striped align-middle table-row-dashed fs-6 gy-3 gs-5" style="width:100%">
                  <thead>
                     <tr class="fw-bold fs-6 text-gray-800 px-7">
                        <th>Item</th>
                        <th>Unit</th>
                        <th>Contract QTY</th>
                        <th>Unit Price</th>
                        <th>Contract Amount</th>
                        <th>Invoiced Qty</th>
                        <th>Invoiced Amount $</th>
                        <th>Paid Qty</th>
                        <th>Unpaid Qty</th>
                        <th>Paid Amount</th>
                        <th class="d-none"></th>
                     </tr>
                  </thead>
                  <tbody class="text-gray-600 fw-semibold"></tbody>
               </table>
            </div>
         </div>
      </div>
   </div>
</div>

<div class="modal fade" id="modal-change-order-history" tabindex="-1" role="dialog" aria-labelledby="modalOverrideHistoryLabel">
   <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
      <div class="modal-content">
         <div class="modal-header">
            <h5 class="modal-title" id="modalOverrideHistoryLabel">History</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
         </div>
         <div class="modal-body">
            <div class="text-center py-5">
               <div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>
            </div>
         </div>
         <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
         </div>
      </div>
   </div>
</div>
{% endblock %}

{% block javascriptsspecific %}
<script src="{{ asset('bundles/metronic8/assets/plugins/custom/datatables/datatables.bundle.js') }}"></script>
<script src="{{ asset('bundles/metronic8/plugins/datatable/fixed-column/dataTables.fixedColumns.min.js') }}"></script>
<script src="{{ asset('bundles/metronic8/plugins/datatable/fixed-column/fixedColumns.bootstrap5.min.js') }}"></script>
<script src="{{ asset('bundles/metronic8/js/pages/override-payment.js') }}?{{ 'now' | date('U') }}"></script>
<script>
   var permiso = {
      agregar: {% if permiso.agregar %}{{ permiso.agregar }}{% else %}0{% endif %},
      editar: {% if permiso.editar %}{{ permiso.editar }}{% else %}0{% endif %},
      eliminar: {% if permiso.eliminar %}{{ permiso.eliminar }}{% else %}0{% endif %}
   };
   var direccion_url = "{{ direccion_url }}";
   jQuery(document).ready(function () {
      OverridePayment.init();
   });
</script>
{% endblock %}
