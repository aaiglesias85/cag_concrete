            font-size: 7pt;
         }
         .bill-to-table td,
         .project-table td,
         .invoice-table td {
            padding: 0.06em 0.1em;
            border: 1px solid #000;
            vertical-align: middle;
         }
         .bill-to-title {
            font-weight: bold;
            background-color: #f2f2f2;
