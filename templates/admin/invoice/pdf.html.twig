   <body>
      <table cellpadding="0" cellspacing="0" border="0" style="width:100%; page-break-inside: avoid; border:none;">
      <tr><td style="border:none; padding:0; vertical-align:top;">
      <table class="header-table sheet-header" cellpadding="0" cellspacing="0">
         <tr>
            <td style="width: 63px; padding: 0;">
               {% if logo_path %}<img src="{{ logo_path }}" alt="Logo" width="60" height="60" style="width:60px;height:60px;object-fit:contain;display:block;" />{% endif %}
            </td>
            <td style="width: 170px; padding: 0 0 0 4px;">
               <table cellpadding="0" cellspacing="0" border="0" style="width:100%;border:none;">
                  <tr>
                     <td colspan="2" style="font-weight:bold;font-size:10pt;color:#000;padding-bottom:4px;">C&amp;G CONCRETE CONSTRUCTION CO., INC.</td>
                  </tr>
                  <tr>
                     <td style="vertical-align:top;font-size:9pt;line-height:1.3;padding-right:8px;">
                        1258 Willingham Dr<br />
                        East Point, Ga. 5025<br />
                        <a href="mailto:data_t@concrete.com" style="color:#4bacc6;">data_t@concrete.com</a>
                     </td>
                     <td style="vertical-align:top;font-size:9pt;line-height:1.3;">
                        Office: 404-254-2017<br />
                        Fax: 404-589-5896<br />
                        <a href="mailto:data_t@concrete.com" style="color:#4bacc6;">data_t@concrete.com</a>
                     </td>
                  </tr>
               </table>
            </td>
            <td class="header-right-cell" style="width: 195px; padding: 0 4px;">
               <table class="bill-to-table">
               <tr>
                  <td colspan="2" class="bill-to-title">BILL TO:</td>
               </tr>
               <tr>
                  <td class="bill-to-label">Contractor's Name:</td>
                  <td class="bill-to-label">Inspector's Name:</td>
               </tr>
               <tr>
                  <td class="bill-to-value">{{ contractor_name|default('') }}</td>
                  <td class="bill-to-value">{{ inspector_name|default('') }}</td>
               </tr>
               <tr>
                  <td class="bill-to-label">Contractor's Phone Number:</td>
                  <td class="bill-to-label">Inspector Cell Number:</td>
               </tr>
               <tr>
                  <td class="bill-to-value">{{ contractor_phone|default('') }}</td>
                  <td class="bill-to-value">{{ inspector_phone|default('') }}</td>
               </tr>
               <tr>
                  <td class="bill-to-label">Contact Name</td>
                  <td class="bill-to-value">{{ contact_name|default('') }}</td>
               </tr>
               <tr>
                  <td class="bill-to-label">Email/No.:</td>
                  <td class="bill-to-value">{{ contact_email|default('') }}</td>
               </tr>
            </table>
            </td>
            <td style="width: 310px; padding: 0;">
               <table class="header-inner-table" cellpadding="0" cellspacing="0" style="width:100%;">
                  <tr>
                     <td style="width: 165px;">
                        <table class="project-table" border="1" cellpadding="0" cellspacing="0" style="border-collapse:collapse;width:100%;">
                           <tr><td class="header-cell-label" style="border:1px solid #000;padding:0.08em;">PROJECT LOCATION:</td><td class="header-cell-value" style="border:1px solid #000;padding:0.08em;">{{ project_location|default('') }}</td></tr>
                           <tr><td class="header-cell-label" style="border:1px solid #000;padding:0.08em;">PROJECT NAME:</td><td class="header-cell-value" style="border:1px solid #000;padding:0.08em;">{{ project_name|default('') }}</td></tr>
                           <tr><td class="header-cell-label" style="border:1px solid #000;padding:0.08em;">PROJECT #</td><td class="header-cell-value" style="border:1px solid #000;padding:0.08em;">{{ project_id_number|default('') }}</td></tr>
                           <tr><td class="header-cell-label" style="border:1px solid #000;padding:0.08em;">PO NUMBER #</td><td class="header-cell-value" style="border:1px solid #000;padding:0.08em;">{{ subcontract|default('') }}</td></tr>
                           <tr><td class="header-cell-label" style="border:1px solid #000;padding:0.08em;">C&amp;G PO#</td><td class="header-cell-value" style="border:1px solid #000;padding:0.08em;">{{ project_number|default('') }}</td></tr>
                        </table>
                     </td>
                     <td style="width: 135px;">
                        <div style="font-weight:bold;font-size:9pt;text-align:right;margin-bottom:0;">INVOICE</div>
                        <table class="invoice-table" border="1" cellpadding="0" cellspacing="0" style="border-collapse:collapse;width:100%;">
                           <tr><td class="invoice-cell-label" style="border:1px solid #000;padding:0.08em;">Date</td><td class="invoice-cell-label" style="border:1px solid #000;padding:0.08em;">Invoice #</td></tr>
                           <tr><td class="invoice-cell-value" style="border:1px solid #000;padding:0.08em;">{{ invoice_date|default('') }}</td><td class="invoice-cell-value" style="border:1px solid #000;padding:0.08em;">{{ invoice_number|default('') }}</td></tr>
                           <tr><td class="invoice-cell-label" style="border:1px solid #000;padding:0.08em;">Start Date</td><td class="invoice-cell-label" style="border:1px solid #000;padding:0.08em;">End Date</td></tr>
                           <tr><td class="invoice-cell-value" style="border:1px solid #000;padding:0.08em;">{{ start_date|default('') }}</td><td class="invoice-cell-value" style="border:1px solid #000;padding:0.08em;">{{ end_date|default('') }}</td></tr>
                        </table>
                     </td>
                  </tr>
               </table>
            </td>
         </tr>
      </table>

      <table class="notes-section" cellpadding="0" cellspacing="0" border="0" style="width:100%; border:1px solid #000; margin:2px 0;">
         <tr>
            <td class="notes-label" style="padding:2px 4px; background-color:#ffc000; font-weight:bold; font-size:8pt;">Notes:</td>
         </tr>
         <tr>
            <td class="notes-content" style="height:18px; padding:4px 6px; background-color:#f9f9f9; font-size:8pt;">{% if notes %}{{ notes|nl2br }}{% else %}&nbsp;{% endif %}</td>
         </tr>
      </table>

      <table border="0" id="items-table" class="sheet-items" style="margin-top:2px;">
         <colgroup>
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
            <col />
         </colgroup>
         <tbody>
            <tr class="row-header">
               <td class="th-item">Item #:</td>
               <td class="th-desc th-desc-border" colspan="3">DESCRIPTION</td>
               <td class="th-unit">UNIT</td>
               <td class="th-unit">UNIT PRICE</td>
               <td class="th-contract-qty">CONTRACT QTY</td>
               <td class="th-contract-amount">CONTRACT AMOUNT</td>
               <td class="th-total-btd">TOTAL QTY BTD</td>
               <td class="th-total-btd">TOTAL AMOUNT BTD</td>
               <td class="th-prev-bill-qty">PREVIOUS BILL QTY</td>
               <td class="th-prev-bill-amount">PREVIOUS BILL AMOUNT</td>
               <td class="th-pending">PENDING QTY (BTD)</td>
               <td class="th-pending">PENDING BALANCE (BTD)</td>
               <td class="th-period-qty">QTY THIS PERIOD</td>
               <td class="th-period-amount">AMOUNT THIS PERIOD</td>
               <td class="cell-right"></td>
               <td class="th-billed-qty">BILLED QTY THIS PERIOD</td>
               <td class="th-billed-amount">BILLED AMOUNT THIS PERIOD</td>
            </tr>

            {% for row in rows %}
            {% if row.header is defined %}
            <tr><td colspan="19" class="style54">{{ row.header }}</td></tr>
            {% else %}
            <tr class="row-item">
               <td class="style18">{{ row.item_number }}</td>
               <td class="style35" colspan="3">{{ row.description }}</td>
               <td class="style19">{{ row.unit }}</td>
               <td class="style19">${{ row.unit_price|number_format(2, '.', ',') }}</td>
               <td class="style19">{{ row.contract_qty|number_format(2, '.', ',') }}</td>
               <td class="style19">${{ row.contract_amount|number_format(2, '.', ',') }}</td>
               <td class="style19">{{ row.total_qty_btd|number_format(2, '.', ',') }}</td>
               <td class="style19">${{ row.total_amount_btd|number_format(2, '.', ',') }}</td>
               <td class="style19">{{ row.previous_bill_qty|number_format(2, '.', ',') }}</td>
               <td class="style19">${{ row.previous_bill_amount|number_format(2, '.', ',') }}</td>
               <td class="style19">{{ row.pending_qty|number_format(2, '.', ',') }}</td>
               <td class="style19">${{ row.pending_balance|number_format(2, '.', ',') }}</td>
               <td class="style19">{{ row.qty_this_period|number_format(2, '.', ',') }}</td>
               <td class="style19">${{ row.amount_this_period|number_format(2, '.', ',') }}</td>
               <td class="cell-right"></td>
               <td class="style19">{{ row.billed_qty|number_format(2, '.', ',') }}</td>
               <td class="style19">${{ row.billed_amount|number_format(2, '.', ',') }}</td>
            </tr>
            {% endif %}
            {% endfor %}

            <tr class="row-totals">
               <td class="td-empty"></td>
               <td class="td-empty-desc td-empty-desc-sm" colspan="3"></td>
               <td class="td-empty"></td>
               <td class="td-total-spacer"></td>
               <td class="td-total-label">TOTAL CONTRACT AMOUNT:</td>
               <td class="td-total-amount-gray">${{ total_contract_amount|number_format(2, '.', ',') }}</td>
               <td class="td-total-btd">TOTAL AMOUNT BTD:</td>
               <td class="td-total-btd">${{ total_amount_btd|number_format(2, '.', ',') }}</td>
               <td class="td-total-prev">TOTAL PREVIOUS BILL AMT:</td>
               <td class="td-total-prev">${{ total_previous_bill|number_format(2, '.', ',') }}</td>
               <td class="td-total-pending-label">TOTAL PENDING BALANCE:</td>
               <td class="td-total-pending-amount">${{ total_pending_balance|number_format(2, '.', ',') }}</td>
               <td class="td-total-period">TOTAL AMT THIS PERIOD:</td>
               <td class="td-total-period">${{ total_amt_this_period|number_format(2, '.', ',') }}</td>
               <td class="cell-right"></td>
               <td class="td-total-billed-label">TOTAL BILLED AMOUNT:</td>
               <td class="td-total-billed-amount">${{ total_billed_amount|number_format(2, '.', ',') }}</td>
            </tr>
            
            {# Fila 1: LESS RETAINAGE (bajo TOTAL AMOUNT BTD) + CURRENT RETAINAGE (bajo TOTAL BILLED AMOUNT) #}
            <tr class="row-summary">
               <td class="td-summary-blank" colspan="8"></td>
               <td class="td-summary-btd-label">LESS RETAINAGE:</td>
               <td class="td-summary-btd">${{ total_retainage_accumulated|number_format(2, '.', ',') }}</td>
               <td class="td-summary-blank" colspan="7"></td>
               <td class="td-summary-billed-label">{{ retainage_label }}</td>
               <td class="td-summary-billed">${{ current_retainage_amount|number_format(2, '.', ',') }}</td>
            </tr>
            {# Fila 2: AMOUNT EARNED LESS RETAINAGE (bajo BTD) + CURRENT AMOUNT DUE (bajo BILLED) #}
            <tr class="row-summary">
               <td class="td-summary-blank" colspan="8"></td>
               <td class="td-summary-btd-label">AMOUNT EARNED LESS RETAINAGE:</td>
               <td class="td-summary-btd">${{ balance_after_retainage|number_format(2, '.', ',') }}</td>
