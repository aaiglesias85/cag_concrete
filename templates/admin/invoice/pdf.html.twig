         }
         .header-table td {
            border: none;
            vertical-align: top;
            padding: 0 2px 0 0;
         }
         .header-logo img {
            width: 60px;
            height: 60px;
            object-fit: contain;
            display: block;
         }
         .header-company .company-name {
            font-weight: bold;
            font-size: 8pt;
            color: #000;
            margin-bottom: 0;
         }
         .header-company .company-col {
            color: #000;
            line-height: 1.1;
            font-size: 7pt;
         }
         .header-company .company-email {
            color: #4bacc6;
            text-decoration: underline;
         }
         .sheet-header {
            page-break-after: avoid;
         }
         .header-right-cell {
            width: 45%;
         }
         .header-block {
            width: 100%;
         }
         .bill-to-table,
