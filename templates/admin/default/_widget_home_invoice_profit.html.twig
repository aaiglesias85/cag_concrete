<div class="col-12 col-md-6 col-xl-4" id="widget-{{ w.id }}">
    <div class="card h-100">
        <div class="card-header border-0 pt-5 d-flex align-items-start justify-content-between flex-nowrap gap-3">
            <div class="card-title align-items-start flex-column m-0 min-w-0">
                <span class="card-label fw-bold text-gray-900 fs-4">{{ w.title }}</span>
                <span class="text-gray-500 fs-6 fw-normal mt-2">{{ w.description }}</span>
            </div>
            <div class="card-toolbar flex-shrink-0">
                <div class="d-flex justify-content-end align-items-center gap-2">
                    {% for link in w.links %}
                        {% if link.canView %}
                            <a href="{{ path(link.route) }}" class="btn btn-sm btn-light" title="Go to module">
                                {{ link.label }}
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
        <div class="card-body pt-0">
            <div class="scroll-y h-250px my-2 px-3">
                <div class="d-flex flex-column h-100">
                    {% set total = home_invoice_profit.total|default(0) %}
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-gray-600 fs-7">Current period total</span>
                        <span class="fw-bold fs-6 home-money {{ total > 0 ? 'home-money-positive' : (total < 0 ? 'home-money-negative' : 'home-money-zero') }}" id="home-total-invoice-profit">
                            {{ total < 0 ? '-$' : '$' }}{{ total|abs|number_format(2, '.', ',') }}
                        </span>
                    </div>
                    <div id="home-chart-invoice-profit" class="min-h-auto flex-grow-1" style="height: 200px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>
