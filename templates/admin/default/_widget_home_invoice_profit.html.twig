<div class="col-12 col-md-6 col-xl-4 mb-5 mb-xl-10" id="widget-{{ w.id }}">
    <div class="card card-flush h-100 shadow-sm">
        <div class="card-header border-0 pt-5 d-flex align-items-start justify-content-between flex-nowrap gap-3">
            <div class="card-title align-items-start flex-column m-0 min-w-0">
                <span class="card-label fw-bold text-gray-800 fs-3">{{ w.title }}</span>
                <span class="text-gray-500 fs-7 fw-semibold mt-1">{{ w.description }}</span>
            </div>
            <div class="card-toolbar flex-shrink-0">
                <div class="d-flex justify-content-end align-items-center gap-2">
                    {% for link in w.links %}
                        {% if link.canView %}
                            <a href="{{ path(link.route) }}" class="btn btn-sm btn-light-success fw-bold" title="Go to module">
                                <i class="ki-duotone ki-dollar fs-4 me-1">
                                    <span class="path1"></span><span class="path2"></span><span class="path3"></span>
                                </i>
                                {{ link.label }}
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
            </div>
        <div class="card-body pt-4 pb-4">
            <div class="d-flex flex-column h-100">
                {% set total = home_invoice_profit.total|default(0) %}
                
                <div class="d-flex flex-stack bg-light-success rounded px-5 py-4 mb-5">
                    <div class="text-success fw-semibold fs-6">Current period total</div>
                    <div class="fw-bold fs-3 text-success" id="home-total-invoice-profit">
                        {{ total < 0 ? '-$' : '$' }}{{ total|abs|number_format(2, '.', ',') }}
                    </div>
                </div>
                <div id="home-chart-invoice-profit" class="min-h-auto flex-grow-1" style="height: 220px;"></div>
                </div>
        </div>
        </div>
    </div>