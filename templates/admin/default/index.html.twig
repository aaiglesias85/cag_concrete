{% extends 'admin/layout.html.twig' %}

{% block subtitle %} - Home{% endblock %}

{% block stylesheetspecific %}{% endblock %}

{% block content %}

    <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
        <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
            <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
                <h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">
                    Home</h1>
                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                    <li class="breadcrumb-item text-muted">
                        <a href="{{ url('home') }}" class="text-muted text-hover-primary">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-500 w-5px h-2px"></span>
                    </li>
                    <li class="breadcrumb-item text-muted">Dashboard</li>
                </ul>
            </div>
            {% if dashboard_widgets is not empty %}
            <div class="d-flex align-items-center gap-2 gap-lg-3 flex-shrink-0">
                <div>
                    <button type="button" class="btn btn-primary"
                            data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end" title="Filter">
                        <i class="ki-duotone ki-filter fs-2"><span class="path1"></span><span class="path2"></span></i>
                        <span class="kt-hidden-mobile font-weight-bold">Filter</span>
                    </button>
                    <div id="filter-menu-home-dashboard" class="menu menu-sub menu-sub-dropdown w-300px w-md-325px" data-kt-menu="true">
                        <div class="px-7 py-5">
                            <div class="fs-5 text-gray-900 fw-bold">Filter options</div>
                        </div>
                        <div class="separator border-gray-200"></div>
                        <div class="px-7 py-5">
                            <div class="mb-5">
                                <label class="form-label text-gray-700" for="home-date-period">Period</label>
                                <select class="form-select form-select-solid" id="home-date-period" name="home-date-period">
                                    <option value="all">All Time</option>
                                    <option value="current_month" selected>Current Month</option>
                                    <option value="last_month">Last Month</option>
                                </select>
                            </div>
                            <div class="mb-5">
                                <label class="form-label text-gray-700" for="home-filter-project">Project</label>
                                <select class="form-select form-select-solid" id="home-filter-project" name="home-filter-project">
                                    <option value=""></option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <div class="input-group input-group-solid date-picker-filter"
                                     id="home-datetimepicker-fecha-desde" data-td-target-input="nearest"
                                     data-td-target-toggle="nearest">
                                    <input type="text" class="form-control form-control-solid filter-date" placeholder="From"
                                           data-td-target="#home-datetimepicker-fecha-desde" autocomplete="off"/>
                                    <span class="input-group-text" data-td-target="#home-datetimepicker-fecha-desde"
                                          data-td-toggle="datetimepicker">
                                        <i class="ki-duotone ki-calendar fs-2"><span class="path1"></span><span class="path2"></span></i>
                                    </span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="input-group input-group-solid date-picker-filter"
                                     id="home-datetimepicker-fecha-hasta" data-td-target-input="nearest"
                                     data-td-target-toggle="nearest">
                                    <input type="text" class="form-control form-control-solid filter-date" placeholder="To"
                                           data-td-target="#home-datetimepicker-fecha-hasta" autocomplete="off"/>
                                    <span class="input-group-text" data-td-target="#home-datetimepicker-fecha-hasta"
                                          data-td-toggle="datetimepicker">
                                        <i class="ki-duotone ki-calendar fs-2"><span class="path1"></span><span class="path2"></span></i>
                                    </span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end mt-10">
                                <button type="button"
                                        class="btn btn-light btn-active-light-primary fw-semibold me-2 px-6"
                                        data-kt-menu-dismiss="true"
                                        id="btn-reset-filtrar-home-task">Reset filters</button>
                                <button type="button" class="btn btn-primary fw-semibold px-6"
                                        data-kt-menu-dismiss="true"
                                        id="btn-filtrar-home-task">Apply</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

    <div id="kt_app_content" class="app-content flex-column-fluid">
        <div id="kt_app_content_container" class="app-container container-fluid">

            {% if dashboard_widgets is empty %}
                <div class="row g-5 g-xl-10">
                    <div class="col-12">
                        <div class="card border-0">
                            <div class="card-body p-10 text-center">
                                <h3 class="fw-bold text-gray-800 mb-3">No dashboard widgets to show</h3>
                                <p class="text-gray-600 mb-0">
                                    You can open the home, but no widget matches your permissions yet.
                                    When you are granted access to tasks, estimates, data tracking, invoices, or other modules, the related cards will appear here.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="row g-4 g-xl-6">
                    {% for w in dashboard_widgets %}
                        {% if w.id is defined and w.id == 'tasks' and home_task is not null %}
                            {% include 'admin/default/_widget_home_tasks.html.twig' with { w: w, home_task: home_task } only %}
                        {% elseif w.id is defined and w.id == 'invoice_profit_share' and home_invoice_profit is not null %}
                            {% include 'admin/default/_widget_home_invoice_profit.html.twig' with { w: w, home_invoice_profit: home_invoice_profit } only %}
                        {% elseif w.id is defined and w.id == 'job_cost_breakdown' and home_cost_breakdown is not null %}
                            {% include 'admin/default/_widget_home_cost_breakdown.html.twig' with { w: w, home_cost_breakdown: home_cost_breakdown } only %}
                        {% else %}
                        <div class="col-12 col-md-6 col-xl-4" id="widget-{{ w.id }}">
                            <div class="card h-100">
                                <div class="card-header border-0 pt-5 min-h-100px d-flex flex-column align-items-stretch">
                                    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 w-100">
                                        <div class="flex-grow-1 me-1">
                                            <h3 class="card-title align-items-start flex-column">
                                                <span class="card-label fw-bold text-gray-900 fs-4">{{ w.title }}</span>
                                                <span class="text-gray-500 fs-6 fw-normal mt-2">{{ w.description }}</span>
                                            </h3>
                                        </div>
                                        <div class="d-flex flex-wrap align-items-center justify-content-end gap-2">
                                            {% for link in w.links %}
                                                {% if link.canView %}
                                                    <a href="{{ path(link.route) }}" class="btn btn-sm btn-light" title="Go to module">
                                                        {{ link.label }}
                                                    </a>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body pt-0">
                                    {% if w.layout is defined and w.layout == 'placeholder' %}
                                        <div class="scroll-y h-250px my-2 px-3">
                                            <div class="border border-dashed border-gray-300 rounded p-8 text-center d-flex flex-column align-items-center justify-content-center bg-light h-100">
                                                <span class="text-muted fw-semibold">{{ w.placeholder_hint|default('Visualization coming soon') }}</span>
                                            </div>
                                        </div>
                                    {% else %}
                                        <div class="scroll-y h-250px my-2 px-3">
                                            <div class="table-responsive">
                                                <table class="table table-row-dashed table-row-gray-200 align-middle gs-0 gy-2">
                                                    <thead>
                                                    <tr class="fs-7 fw-bold text-gray-500 text-nowrap">
                                                        {% for col in w.columns %}
                                                            <th class="pe-0">
                                                                <span class="d-inline-block" style="max-width: 12rem; white-space: normal;">{{ col }}</span>
                                                            </th>
                                                        {% endfor %}
                                                    </tr>
                                                    </thead>
                                                    <tbody>
                                                    <tr>
                                                        {% for _ in w.columns %}
                                                            <td>
                                                                <span class="text-muted">—</span>
                                                            </td>
                                                        {% endfor %}
                                                    </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </div>

{% endblock %}

{% block javascriptsspecific %}
    {% if dashboard_widgets is not empty %}
    <script>
        window.HomeTaskConfig = {
            urlList: {% if home_task is not null %}{{ path('listarTaskHome')|json_encode|raw }}{% else %}null{% endif %},
            urlSave: {% if home_task is not null %}{{ path('salvarTaskAdmin')|json_encode|raw }}{% else %}null{% endif %},
            urlCambioEstado: {% if home_task is not null %}{{ path('cambiarEstadoTaskAdmin')|json_encode|raw }}{% else %}null{% endif %},
            invoiceProfitData: {% if home_invoice_profit is not null %}{{ home_invoice_profit|json_encode|raw }}{% else %}null{% endif %},
            costBreakdownData: {% if home_cost_breakdown is not null %}{{ home_cost_breakdown|json_encode|raw }}{% else %}null{% endif %},
            urlDashboardStats: {{ path('listarStatsDashboard')|json_encode|raw }}
        };
    </script>
    {% if home_task is not null %}
    <script src="{{ asset('bundles/metronic8/assets/plugins/custom/datatables/datatables.bundle.js') }}"></script>
    {% endif %}
    <script src="{{ asset('bundles/metronic8/js/pages/index.js') }}?{{ 'now'|date('U') }}"></script>
    <script>
        jQuery(function () { Index.init(); });
    </script>
    {% endif %}
{% endblock %}
