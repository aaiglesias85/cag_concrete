<div class="col-12 mb-5 mb-xl-10" id="widget-{{ w.id }}">
    <div class="card card-flush h-100 shadow-sm">
        <div class="card-header border-0 pt-5 d-flex align-items-start justify-content-between flex-nowrap gap-3">
            <div class="card-title align-items-start flex-column m-0 min-w-0">
                <span class="card-label fw-bold text-gray-800 fs-3">{{ w.title }}</span>
                <span class="text-gray-500 fs-7 fw-semibold mt-1">{{ w.description }}</span>
            </div>
            <div class="card-toolbar flex-shrink-0">
                <div class="d-flex justify-content-end align-items-center gap-3">
                    <span class="text-gray-500 fs-8 fw-semibold text-nowrap" id="home-pco-period-label">Current Month</span>
                    <div>
                        <button type="button" class="btn btn-sm btn-primary"
                                data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end" title="Filter">
                            <i class="ki-duotone ki-filter fs-4"><span class="path1"></span><span class="path2"></span></i>
                            Filter
                        </button>
                        <div id="filter-menu-pco" class="menu menu-sub menu-sub-dropdown w-300px w-md-325px" data-kt-menu="true">
                            <div class="px-7 py-5">
                                <div class="fs-5 text-gray-900 fw-bold">Filter options</div>
                            </div>
                            <div class="separator border-gray-200"></div>
                            <div class="px-7 py-5">
                                <div class="mb-5">
                                    <label class="form-label text-gray-700" for="pco-date-period">Period</label>
                                    <select class="form-select form-select-solid" id="pco-date-period" name="pco-date-period">
                                        <option value="all">All Time</option>
                                        <option value="current_month" selected>Current Month</option>
                                        <option value="last_month">Last Month</option>
                                    </select>
                                </div>
                                <div class="mb-5">
                                    <label class="form-label text-gray-700" for="pco-filter-project">Project</label>
                                    <select class="form-select form-select-solid" id="pco-filter-project" name="pco-filter-project">
                                        <option value=""></option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <div class="input-group input-group-solid"
                                         id="pco-datetimepicker-fecha-desde"
                                         data-td-target-input="nearest" data-td-target-toggle="nearest">
                                        <input type="text" class="form-control form-control-solid" placeholder="From"
                                               data-td-target="#pco-datetimepicker-fecha-desde" autocomplete="off"/>
                                        <span class="input-group-text" data-td-target="#pco-datetimepicker-fecha-desde"
                                              data-td-toggle="datetimepicker">
                                            <i class="ki-duotone ki-calendar fs-2"><span class="path1"></span><span class="path2"></span></i>
                                        </span>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="input-group input-group-solid"
                                         id="pco-datetimepicker-fecha-hasta"
                                         data-td-target-input="nearest" data-td-target-toggle="nearest">
                                        <input type="text" class="form-control form-control-solid" placeholder="To"
                                               data-td-target="#pco-datetimepicker-fecha-hasta" autocomplete="off"/>
                                        <span class="input-group-text" data-td-target="#pco-datetimepicker-fecha-hasta"
                                              data-td-toggle="datetimepicker">
                                            <i class="ki-duotone ki-calendar fs-2"><span class="path1"></span><span class="path2"></span></i>
                                        </span>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-end mt-10">
                                    <button type="button"
                                            class="btn btn-light btn-active-light-primary fw-semibold me-2 px-6"
                                            data-kt-menu-dismiss="true"
                                            id="btn-reset-pco-filter">Reset filters</button>
                                    <button type="button" class="btn btn-primary fw-semibold px-6"
                                            data-kt-menu-dismiss="true"
                                            id="btn-apply-pco-filter">Apply</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% for link in w.links %}
                        {% if link.canView %}
                            <a href="{{ path(link.route) }}" class="btn btn-sm btn-light-primary fw-bold" title="Go to module">
                                {{ link.label }}
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
        <div class="card-body pt-4 pb-6">
            <div class="row g-6 g-xl-9">

                {# ── Left: Daily Job Costs totals ── #}
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="fw-bold text-gray-700 fs-6 mb-3">Daily Job Costs totals</div>
                    {% set costs_total = home_profit_cost_overview.costs.total|default(0) %}
                    <div class="d-flex flex-stack bg-light-primary rounded px-5 py-3 mb-4">
                        <div class="text-primary fw-semibold fs-7">Total Costs</div>
                        <div class="fw-bold fs-4 text-primary" id="home-pco-total-costs">
                            {{ costs_total < 0 ? '-$' : '$' }}{{ costs_total|abs|number_format(2, '.', ',') }}
                        </div>
                    </div>
                    <div id="home-chart-pco-costs" style="height: 240px;"></div>
                </div>

                {# ── Center: Actual Gross Profit ── #}
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="fw-bold text-gray-700 fs-6 mb-3">Actual Gross Profit</div>
                    {% set gp = home_profit_cost_overview.gross_profit|default({}) %}
                    {% set gross_profit = gp.actual_gross_profit|default(0) %}
                    <div class="d-flex flex-stack bg-light-success rounded px-5 py-3 mb-4">
                        <div class="text-success fw-semibold fs-7">Calculated Profit from Daily Tracking</div>
                        <div class="fw-bold fs-4 {{ gross_profit >= 0 ? 'text-success' : 'text-danger' }}" id="home-pco-gross-profit">
                            {{ gross_profit < 0 ? '-$' : '$' }}{{ gross_profit|abs|number_format(2, '.', ',') }}
                        </div>
                    </div>
                    <div id="home-chart-pco-gross-profit" style="height: 240px;"></div>
                </div>

                {# ── Right: Total Payments Against Invoices ── #}
                <div class="col-12 col-xl-4">
                    <div class="fw-bold text-gray-700 fs-6 mb-3">Total Payments Against Invoices</div>
                    {% set pay = home_profit_cost_overview.payments|default({}) %}
                    {% set pct = pay.porciento|default(0) %}
                    {% set pct_display = pct > 100 ? 100 : pct %}
                    {% set received = pay.received|default(0) %}
                    {% set invoiced = pay.invoiced|default(0) %}

                    <div class="mb-6">
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge badge-success fs-4 fw-bold px-4 py-3 me-3" id="home-pco-payments-pct">{{ pct }}%</span>
                            <span class="text-gray-500 fs-7">of Invoice totals received</span>
                        </div>
                        <div class="bg-light rounded overflow-hidden" style="height: 20px;">
                            <div class="bg-success rounded h-100" id="home-pco-payments-bar"
                                 style="width: {{ pct_display }}%; transition: width 0.6s ease;"></div>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-4 mt-5">
                        <div class="d-flex justify-content-between align-items-center border-bottom border-dashed border-gray-200 pb-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="bullet bullet-dot bg-success h-10px w-10px"></span>
                                <span class="text-gray-700 fs-7 fw-semibold">Payments totals</span>
                            </div>
                            <span class="fw-bold text-success fs-6" id="home-pco-received">
                                ${{ received|number_format(2, '.', ',') }}
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <span class="bullet bullet-dot bg-secondary h-10px w-10px"></span>
                                <span class="text-gray-700 fs-7 fw-semibold">Invoice totals</span>
                            </div>
                            <span class="fw-bold text-gray-600 fs-6" id="home-pco-invoiced">
                                ${{ invoiced|number_format(2, '.', ',') }}
                            </span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
