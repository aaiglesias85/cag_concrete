{% extends 'admin/layout.html.twig' %}

{% block subtitle %} - My Widgets{% endblock %}

{% block content %}
<div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <div id="kt_app_toolbar_container" class="app-container container-fluid d-flex flex-stack">
        <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
            <h1 class="page-heading d-flex text-gray-900 fw-bold fs-3 flex-column justify-content-center my-0">My Widgets</h1>
            <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
                <li class="breadcrumb-item text-muted">
                    <a href="{{ url('home') }}" class="text-muted text-hover-primary">Home</a>
                </li>
                <li class="breadcrumb-item"><span class="bullet bg-gray-500 w-5px h-2px"></span></li>
                <li class="breadcrumb-item text-muted">My Widgets</li>
            </ul>
        </div>
    </div>
</div>

<div id="kt_app_content" class="app-content flex-column-fluid">
    <div id="kt_app_content_container" class="app-container container-fluid">

        <div class="card">
            <div class="card-header border-0 pt-6">
                <div class="card-title">
                    <span class="text-gray-600 fs-6">Choose which widgets to display on your Home dashboard. You can only toggle widgets your admin has granted you access to.</span>
                </div>
            </div>
            <div class="card-body pt-0">

                {% if widgets is empty %}
                    <div class="text-center text-muted py-10">
                        <p>You have no widgets available. Contact your administrator to request access.</p>
                    </div>
                {% else %}
                    <div class="row g-4">
                        {% for w in widgets %}
                        <div class="col-12 col-md-6 col-xl-4">
                            <div class="card border border-gray-200 h-100">
                                <div class="card-body d-flex align-items-start justify-content-between gap-3 p-5">
                                    <div class="min-w-0">
                                        <div class="fw-bold text-gray-800 fs-6 mb-1">{{ w.title }}</div>
                                        <div class="text-gray-500 fs-7">{{ w.description }}</div>
                                    </div>
                                    <div class="form-check form-switch form-check-custom form-check-solid flex-shrink-0">
                                        <input
                                            class="form-check-input widget-toggle"
                                            type="checkbox"
                                            data-widget-id="{{ w.id }}"
                                            {% if w.user_active %}checked{% endif %}
                                        />
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% endif %}

            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block javascriptsspecific %}
<script>
document.querySelectorAll('.widget-toggle').forEach(function (toggle) {
    toggle.addEventListener('change', function () {
        var widgetId = this.dataset.widgetId;
        var isActive = this.checked;
        var formData = new FormData();
        formData.append('widget_id', widgetId);
        formData.append('is_active', isActive ? '1' : '0');

        fetch('{{ urlSave }}', { method: 'POST', body: formData })
            .then(function (r) { return r.json(); })
            .catch(function () {
                toggle.checked = !isActive;
            });
    });
});
</script>
{% endblock %}
