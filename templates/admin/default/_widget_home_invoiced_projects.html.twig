<div class="col-12 col-md-6 col-xl-4 mb-5 mb-xl-10" id="widget-invoiced_projects">
    <div class="card card-flush h-100 shadow-sm">
        <div class="card-header border-0 pt-5 d-flex align-items-start justify-content-between flex-nowrap gap-3">
            <div class="card-title align-items-start flex-column m-0 min-w-0">
                <span class="card-label fw-bold text-gray-800 fs-3">{{ w.title }}</span>
                <span class="text-gray-500 fs-7 fw-semibold mt-1">{{ w.description }}</span>
            </div>
            <div class="card-toolbar flex-shrink-0">
                <div class="d-flex justify-content-end align-items-center gap-2">
                    {% for link in w.links %}
                        {% if link.canView %}
                            <a href="{{ path(link.route) }}" class="btn btn-sm btn-light-primary fw-bold" title="Open invoice module">
                                <i class="ki-duotone ki-bank fs-4 me-1">
                                    <span class="path1"></span><span class="path2"></span>
                                </i>
                                {{ link.label }}
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
            </div>
        <div class="card-body pt-4 pb-4">
            <div class="scroll-y h-250px pe-3">
                <div class="table-responsive">
                    <table class="table table-row-dashed table-hover table-row-gray-200 align-middle gs-0 gy-4">
                        <thead>
                            <tr class="fw-bold text-muted text-uppercase fs-8 text-nowrap">
                                <th class="min-w-140px">Project</th>
                                <th class="min-w-100px">Invoice</th>
                                <th class="min-w-120px text-end pe-3">Amount Total</th>
                            </tr>
                        </thead>
                        <tbody id="home-invoiced-projects-tbody">
                        {% for row in home_invoiced_projects %}
                            {% set amount = row.amount_total|default(0) %}
                            <tr data-invoice-id="{{ row.id }}" style="cursor: pointer;">
                                <td>
                                    <span class="text-gray-800 fw-bold text-hover-primary mb-1 fs-7">{{ row.project_label ?: '—' }}</span>
                                </td>
                                <td>
                                    <span class="badge badge-light-secondary text-gray-600 fw-bold fs-8">{{ row.invoice_label|default('—') }}</span>
                                </td>
                                <td class="text-end pe-3">
                                    <span class="fw-bold fs-7 {{ amount > 0 ? 'text-success' : (amount < 0 ? 'text-danger' : 'text-gray-800') }}">
                                        {{ amount < 0 ? '-$' : '$' }}{{ amount|abs|number_format(2, '.', ',') }}
                                    </span>
                                </td>
                            </tr>
                        {% else %}
                            <tr id="home-invoiced-projects-empty-row">
                                <td colspan="3" class="text-center">
                                    <div class="d-flex flex-column align-items-center justify-content-center py-10">
                                        <i class="ki-duotone ki-file-sheet fs-3x text-muted mb-4"><span class="path1"></span><span class="path2"></span></i>
                                        <span class="text-muted fw-semibold fs-6">No invoices in this range.</span>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                        </table>
                </div>
                </div>
            </div>
        </div>
    </div>