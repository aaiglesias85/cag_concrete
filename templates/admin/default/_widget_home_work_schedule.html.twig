<div class="col-12 col-md-6 col-xl-4 mb-5 mb-xl-10" id="widget-work_schedule">
    <div class="card card-flush h-100 shadow-sm">
        <div class="card-header border-0 pt-5 d-flex align-items-start justify-content-between flex-nowrap gap-3">
            <div class="card-title align-items-start flex-column m-0 min-w-0">
                <span class="card-label fw-bold text-gray-800 fs-3">{{ w.title }}</span>
                <span class="text-gray-500 fs-7 fw-semibold mt-1">{{ w.description }}</span>
            </div>
            <div class="card-toolbar flex-shrink-0">
                <div class="d-flex justify-content-end align-items-center gap-2">
                    {% for link in w.links %}
                        {% if link.canView %}
                            <a href="{{ path(link.route) }}" class="btn btn-sm btn-light-warning fw-bold" title="Open schedule module">
                                <i class="ki-duotone ki-calendar-8 fs-4 me-1">
                                    <span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span><span class="path6"></span>
                                </i>
                                {{ link.label }}
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
            </div>
        <div class="card-body pt-4 pb-4">
            <div class="scroll-y h-250px pe-3">
                <div class="table-responsive">
                    <table class="table table-row-dashed table-hover table-row-gray-200 align-middle gs-0 gy-4">
                        <thead>
                            <tr class="fw-bold text-muted text-uppercase fs-8 text-nowrap">
                                <th class="min-w-100px">Project #</th>
                                <th class="min-w-100px">Day</th>
                                <th class="min-w-80px text-end">Priority</th>
                            </tr>
                        </thead>
                        <tbody id="home-work-schedule-tbody">
                        {% for row in home_work_schedule %}
                            <tr data-schedule-id="{{ row.id }}">
                                <td>
                                    {% if row.project_id|default(0) > 0 %}
                                        <a href="javascript:;" class="project-link text-gray-900 fw-bold text-hover-primary mb-1 fs-6" data-project-id="{{ row.project_id }}">
                                            {{ row.project_number|default('—') }}
                                        </a>
                                    {% else %}
                                        <span class="text-gray-900 fw-bold fs-6">{{ row.project_number|default('—') }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="text-muted fw-semibold d-block fs-7">
                                        <i class="ki-duotone ki-time fs-6 me-1"><span class="path1"></span><span class="path2"></span></i>
                                        {{ row.day|default('—') }}
                                    </span>
                                </td>
                                <td class="text-end">
                                    {% if row.highpriority|default(false) %}
                                        <span class="badge badge-light-danger fw-bold px-3 py-2">{{ row.priority_label|default('High') }}</span>
                                    {% else %}
                                        <span class="badge badge-light-primary fw-bold px-3 py-2">{{ row.priority_label|default('Normal') }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr id="home-work-schedule-empty-row">
                                <td colspan="3" class="text-center">
                                    <div class="d-flex flex-column align-items-center justify-content-center py-10">
                                        <i class="ki-duotone ki-calendar-remove fs-3x text-muted mb-4"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span><span class="path6"></span></i>
                                        <span class="text-muted fw-semibold fs-6">No schedules in this range.</span>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                        </table>
                </div>
                </div>
            </div>
        </div>
    </div>