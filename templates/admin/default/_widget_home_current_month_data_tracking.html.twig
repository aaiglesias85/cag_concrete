<div class="col-12 col-md-12 col-xl-12 mb-5 mb-xl-10" id="widget-current_month_data_tracking">
    <div class="card card-flush h-100 shadow-sm">
        <div class="card-header border-0 pt-5 d-flex align-items-start justify-content-between flex-nowrap gap-3">
            <div class="card-title align-items-start flex-column m-0 min-w-0">
                <span class="card-label fw-bold text-gray-800 fs-3">{{ w.title }}</span>
                <span class="text-gray-500 fs-7 fw-semibold mt-1">{{ w.description }}</span>
            </div>
            <div class="card-toolbar flex-shrink-0">
                <div class="d-flex justify-content-end align-items-center gap-2">
                    {# ── Unified filter ── #}
                    <div>
                        <button type="button" class="btn btn-sm btn-light fw-semibold fs-8 px-3 d-flex align-items-center gap-1" id="dt-filter-btn"
                                data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                            <i class="ki-duotone ki-filter fs-5"><span class="path1"></span><span class="path2"></span></i>
                            <span id="dt-filter-label">Current month</span>
                        </button>
                        <div id="dt-filter-menu" class="menu menu-sub menu-sub-dropdown w-300px" data-kt-menu="true">
                            <div class="px-7 py-5">
                                <div class="fs-5 text-gray-900 fw-bold">Filter</div>
                            </div>
                            <div class="separator border-gray-200"></div>
                            <div class="px-7 py-5">
                                <div class="mb-3">
                                    <label class="form-label text-gray-700 fs-7">Period</label>
                                    <select class="form-select form-select-sm bg-body border border-gray-300 text-gray-700 fw-semibold" id="dt-period-select" style="border-radius:0.475rem">
                                        <option value="all">All time</option>
                                        <option value="current_month" selected>Current month</option>
                                        <option value="last_month">Last month</option>
                                        <option value="custom">Custom range</option>
                                    </select>
                                </div>
                                <div class="row g-2 mb-3" id="dt-custom-range" style="display:none">
                                    <div class="col-6">
                                        <label class="form-label text-gray-700 fs-7">From</label>
                                        <input type="date" class="form-control form-control-sm" id="dt-date-from" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label text-gray-700 fs-7">To</label>
                                        <input type="date" class="form-control form-control-sm" id="dt-date-to" />
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-gray-700 fs-7">Project</label>
                                    <select class="form-select form-select-solid form-select-sm" id="dt-filter-project">
                                        <option value=""></option>
                                    </select>
                                </div>
                                <div class="d-flex justify-content-end mt-4">
                                    <button type="button" class="btn btn-light btn-active-light-primary fw-semibold me-2 px-6"
                                            data-kt-menu-dismiss="true" id="dt-btn-reset">Reset</button>
                                    <button type="button" class="btn btn-primary fw-semibold px-6"
                                            data-kt-menu-dismiss="true" id="dt-btn-apply">Apply</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% for link in w.links %}
                        {% if link.canView %}
                            <a href="{{ path(link.route) }}" class="btn btn-sm btn-light-primary fw-bold" title="Open data tracking module">
                                <i class="ki-duotone ki-chart-line-star fs-4 me-1">
                                    <span class="path1"></span><span class="path2"></span><span class="path3"></span>
                                </i>
                                {{ link.label }}
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
        <div class="card-body pt-4 pb-4">
            <div class="h-400px pe-3" style="overflow:auto;">
                    <table class="table table-row-dashed table-row-gray-200 align-middle gs-0 gy-2" id="dt-widget-table">
                        <thead style="position: sticky; top: 0; z-index: 2; background: var(--kt-card-bg, #fff);">
                            <tr class="fw-bold text-muted text-uppercase fs-8 text-nowrap">
                                <th class="w-30px"></th>
                                <th class="min-w-120px">Project</th>
                                <th class="min-w-110px text-end">Total</th>
                                <th class="min-w-110px text-end">Profit</th>
                                <th class="min-w-110px text-end">Labor</th>
                                <th class="min-w-110px text-end pe-3">Concrete</th>
                            </tr>
                        </thead>
                        <tbody id="home-current-month-data-tracking-tbody">
                        {% for proj in home_current_month_data_tracking %}
                            {% set daily = proj.total_daily_today|default(0) %}
                            {% set profit = proj.profit|default(0) %}
                            {% set labor = proj.totalLabor|default(0) %}
                            {% set concrete = proj.total_concrete|default(0) %}
                            {% set rowId = 'dt-proj-' ~ loop.index %}
                            <tr class="dt-project-row fw-bold fs-7" data-bs-toggle="collapse" data-bs-target="#{{ rowId }}" style="cursor:pointer;">
                                <td class="text-center">
                                    <i class="ki-duotone ki-down fs-6 text-gray-500 dt-chevron"><span class="path1"></span></i>
                                </td>
                                <td>
                                    <a href="javascript:;" class="dt-project-link badge badge-light-primary text-gray-800 fw-bold fs-7"
                                       data-project-id="{{ proj.project_id|default(0) }}"
                                       onclick="event.stopPropagation();">
                                        {{ proj.project_number }}
                                    </a>
                                </td>
                                <td class="text-end">
                                    <span class="fw-bold fs-7 {{ daily > 0 ? 'text-success' : (daily < 0 ? 'text-danger' : 'text-gray-600') }}">
                                        {{ daily < 0 ? '-$' : '$' }}{{ daily|abs|number_format(2, '.', ',') }}
                                    </span>
                                </td>
                                <td class="text-end">
                                    <span class="fw-bold fs-7 {{ profit > 0 ? 'text-success' : (profit < 0 ? 'text-danger' : 'text-gray-600') }}">
                                        {{ profit < 0 ? '-$' : '$' }}{{ profit|abs|number_format(2, '.', ',') }}
                                    </span>
                                </td>
                                <td class="text-end">
                                    <span class="fw-bold fs-7 text-gray-700">
                                        {{ labor < 0 ? '-$' : '$' }}{{ labor|abs|number_format(2, '.', ',') }}
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <span class="fw-bold fs-7 text-gray-700">
                                        {{ concrete < 0 ? '-$' : '$' }}{{ concrete|abs|number_format(2, '.', ',') }}
                                    </span>
                                </td>
                            </tr>
                            <tr class="dt-detail-row">
                                <td colspan="6" class="p-0 border-0">
                                    <div class="collapse" id="{{ rowId }}">
                                        {# <div class="bg-light-primary rounded mx-2 mb-2 px-3 py-2"> #}
                                        <div class="rounded mx-2 mb-2 px-3 py-2">
                                            <table class="table table-sm table-row-gray-300 align-middle mb-0 gs-0 gy-1">
                                                <thead class="dt-sub-thead" style="position:sticky;top:36px;z-index:1;background:var(--kt-card-bg,#fff);">
                                                    <tr class="fw-bold text-muted text-uppercase fs-9">
                                                        <th class="min-w-80px">Date</th>
                                                        <th class="min-w-80px">Lead</th>
                                                        <th class="min-w-90px text-end">Daily Total</th>
                                                        <th class="min-w-90px text-end">Profit</th>
                                                        <th class="min-w-90px text-end">Labor</th>
                                                        <th class="min-w-90px text-end">Concrete</th>
                                                        <th class="min-w-120px pe-2">Items</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                {% for entry in proj.entries %}
                                                    {% set ed = entry.total_daily_today|default(0) %}
                                                    {% set ep = entry.profit|default(0) %}
                                                    {% set el = entry.totalLabor|default(0) %}
                                                    {% set ec = entry.total_concrete|default(0) %}
                                                    <tr>
                                                        <td>
                                                            <a href="javascript:;" class="dt-nav-link text-gray-700 fs-8"
                                                               data-dt-id="{{ entry.id }}" data-dt-tab="1">
                                                                {{ entry.date|default('—') }}
                                                            </a>
                                                        </td>
                                                        <td>
                                                            {% if entry.crew_lead|default('') is not empty %}
                                                                <a href="javascript:;" class="dt-nav-link text-gray-700 fs-8"
                                                                   data-dt-id="{{ entry.id }}" data-dt-tab="3">
                                                                    {{ entry.crew_lead }}
                                                                </a>
                                                            {% else %}
                                                                <span class="text-muted fs-8">—</span>
                                                            {% endif %}
                                                        </td>
                                                        <td class="text-end">
                                                            <span class="fs-8 {{ ed > 0 ? 'text-success fw-semibold' : (ed < 0 ? 'text-danger fw-semibold' : 'text-gray-600') }}">
                                                                {{ ed < 0 ? '-$' : '$' }}{{ ed|abs|number_format(2, '.', ',') }}
                                                            </span>
                                                        </td>
                                                        <td class="text-end">
                                                            <span class="fs-8 {{ ep > 0 ? 'text-success fw-semibold' : (ep < 0 ? 'text-danger fw-semibold' : 'text-gray-600') }}">
                                                                {{ ep < 0 ? '-$' : '$' }}{{ ep|abs|number_format(2, '.', ',') }}
                                                            </span>
                                                        </td>
                                                        <td class="text-end">
                                                            <span class="text-gray-700 fs-8">
                                                                {{ el < 0 ? '-$' : '$' }}{{ el|abs|number_format(2, '.', ',') }}
                                                            </span>
                                                        </td>
                                                        <td class="text-end">
                                                            <a href="javascript:;" class="dt-nav-link text-gray-700 fs-8"
                                                               data-dt-id="{{ entry.id }}" data-dt-tab="5">
                                                                {{ ec < 0 ? '-$' : '$' }}{{ ec|abs|number_format(2, '.', ',') }}
                                                            </a>
                                                        </td>
                                                        <td class="pe-2">
                                                            {% if entry.items_label|default('') is not empty %}
                                                                <a href="javascript:;" class="dt-nav-link text-gray-600 fs-8 dt-items-label"
                                                                   data-dt-id="{{ entry.id }}" data-dt-tab="2"
                                                                   data-bs-toggle="tooltip" data-bs-placement="top"
                                                                   title="{{ entry.items_label }}">
                                                                    {{ entry.items_label|slice(0, 30) }}{% if entry.items_label|length > 30 %}…{% endif %}
                                                                </a>
                                                            {% else %}
                                                                <span class="text-muted fs-8">—</span>
                                                            {% endif %}
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr id="home-current-month-data-tracking-empty-row">
                                <td colspan="6" class="text-center">
                                    <div class="d-flex flex-column align-items-center justify-content-center py-10">
                                        <i class="ki-duotone ki-graph-up fs-3x text-muted mb-4"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span><span class="path5"></span><span class="path6"></span></i>
                                        <span class="text-muted fw-semibold fs-6">No data tracking records in this range.</span>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    var dtActivePeriod = 'current_month';

    /* ── helpers de fecha ─────────────────────────────────────── */
    function fmtDate(d) {
        var m = String(d.getMonth() + 1).padStart(2, '0');
        var day = String(d.getDate()).padStart(2, '0');
        return m + '/' + day + '/' + d.getFullYear();
    }
    function getMonthBounds(offset) {
        var now = new Date();
        var first = new Date(now.getFullYear(), now.getMonth() + offset, 1);
        var last  = new Date(now.getFullYear(), now.getMonth() + offset + 1, 0);
        return { fi: fmtDate(first), ff: fmtDate(last),
                 label: first.toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) };
    }

    /* ── actualizar filtros globales del dashboard ────────────── */
    function setGlobalPeriod(period, fi, ff) {
        var $sel = typeof $ !== 'undefined' ? $('#home-date-period') : null;
        if ($sel && $sel.length) {
            $sel.hasClass('select2-hidden-accessible')
                ? $sel.val(period).trigger('change')
                : $sel.val(period);
        }
        if (typeof FlatpickrUtil !== 'undefined') {
            if (fi) FlatpickrUtil.setDate('home-datetimepicker-fecha-desde', fi);
            else    FlatpickrUtil.clear('home-datetimepicker-fecha-desde');
            if (ff) FlatpickrUtil.setDate('home-datetimepicker-fecha-hasta', ff);
            else    FlatpickrUtil.clear('home-datetimepicker-fecha-hasta');
        }
    }
    function setGlobalProject(projectId, projectText) {
        if (typeof $ === 'undefined') return;
        var $proj = $('#home-filter-project');
        if (!$proj.length) return;
        if (!projectId) {
            $proj.hasClass('select2-hidden-accessible')
                ? $proj.val(null).trigger('change')
                : $proj.val('');
            return;
        }
        if ($proj.hasClass('select2-hidden-accessible')) {
            /* Select2 AJAX necesita que la opción exista en el DOM primero */
            if (!$proj.find('option[value="' + projectId + '"]').length) {
                $proj.append(new Option(projectText || projectId, projectId, true, true));
            }
            $proj.val(projectId).trigger('change');
        } else {
            $proj.val(projectId);
        }
    }

    /* ── label del botón ─────────────────────────────────────── */
    function updateLabel(periodLabel, projText) {
        var el  = document.getElementById('dt-filter-label');
        var btn = document.getElementById('dt-filter-btn');
        if (el)  el.textContent = periodLabel + (projText ? ' · ' + projText : '');
        if (btn) {
            var active = !!projText || periodLabel !== 'Current month';
            btn.classList.toggle('btn-light',        !active);
            btn.classList.toggle('btn-light-primary', active);
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        var periodSel = document.getElementById('dt-period-select');
        var customRow = document.getElementById('dt-custom-range');

        /* mostrar/ocultar fechas custom */
        if (periodSel && customRow) {
            periodSel.addEventListener('change', function () {
                customRow.style.display = this.value === 'custom' ? '' : 'none';
            });
        }

        /* Select2 solo para project */
        if (typeof $ !== 'undefined' && $.fn && $.fn.select2) {
            $('#dt-filter-project').select2({
                placeholder: 'Search project…', allowClear: true, width: '100%',
                dropdownParent: $('#dt-filter-menu'),
                ajax: {
                    url: 'project/listarOrdenados', dataType: 'json', delay: 250,
                    data: function (p) { return { search: p.term }; },
                    processResults: function (d) {
                        return { results: $.map(d.projects || [], function (i) {
                            return { id: i.project_id, text: (i.number || '') + ' - ' + (i.description || '') };
                        })};
                    },
                    cache: true
                },
                minimumInputLength: 3
            });
        }

        /* ── Apply ───────────────────────────────────────────── */
        var applyBtn = document.getElementById('dt-btn-apply');
        if (applyBtn) applyBtn.addEventListener('click', function () {
            var period = periodSel ? periodSel.value : 'current_month';
            var fi = '', ff = '', periodLabel = 'Current month';

            if (period === 'all') {
                periodLabel = 'All time';
            } else if (period === 'current_month') {
                var cm = getMonthBounds(0);  fi = cm.fi; ff = cm.ff; periodLabel = cm.label;
            } else if (period === 'last_month') {
                var lm = getMonthBounds(-1); fi = lm.fi; ff = lm.ff; periodLabel = lm.label;
            } else if (period === 'custom') {
                var fromEl = document.getElementById('dt-date-from');
                var toEl   = document.getElementById('dt-date-to');
                var fiIso  = fromEl ? fromEl.value : '';
                var ffIso  = toEl   ? toEl.value   : '';
                if (fiIso && ffIso) {
                    var fp = fiIso.split('-'); fi = fp[1]+'/'+fp[2]+'/'+fp[0];
                    var tp = ffIso.split('-'); ff = tp[1]+'/'+tp[2]+'/'+tp[0];
                    period = 'all'; /* 'all' + fechas → getPeriodParams lo detecta como custom */
                    periodLabel = fi + ' – ' + ff;
                } else {
                    return; /* fechas incompletas, no hacer nada */
                }
            }

            /* capturar proyecto ANTES de que KTMenu cierre el dropdown */
            var projectId   = (typeof $ !== 'undefined' ? ($('#dt-filter-project').val() || '') : '');
            var projText    = '';
            var projFullText = '';
            if (projectId && typeof $ !== 'undefined') {
                var sel = $('#dt-filter-project').select2('data');
                if (sel && sel[0]) {
                    projFullText = sel[0].text || '';
                    projText = projFullText.split(' - ')[0].trim();
                }
            }

            /* actualizar filtros globales y recargar */
            setGlobalPeriod(period, fi, ff);
            setGlobalProject(projectId, projFullText);
            dtActivePeriod = period;

            /* reloadDashboardData() está dentro de un IIFE, no es global.
               Disparamos el click del botón Apply global que ya está enlazado. */
            if (typeof $ !== 'undefined' && $('#btn-filtrar-home-task').length) {
                $('#btn-filtrar-home-task').trigger('click');
            }
            updateLabel(periodLabel, projText);
        });

        /* ── Reset ───────────────────────────────────────────── */
        var resetBtn = document.getElementById('dt-btn-reset');
        if (resetBtn) resetBtn.addEventListener('click', function () {
            if (periodSel) periodSel.value = 'current_month';
            if (customRow) customRow.style.display = 'none';
            var cm = getMonthBounds(0);
            setGlobalPeriod('current_month', cm.fi, cm.ff);
            setGlobalProject('');
            dtActivePeriod = 'current_month';
            if (typeof $ !== 'undefined') $('#dt-filter-project').val(null).trigger('change');
            if (typeof $ !== 'undefined' && $('#btn-filtrar-home-task').length) {
                $('#btn-filtrar-home-task').trigger('click');
            }
            updateLabel(cm.label, '');
        });
    });
}());
</script>
