<!-- Modal Exit: Save or discard changes -->
<div class="modal fade" id="modal-salvar-cambios" tabindex="-1" role="dialog" aria-labelledby="modalExitLabel">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalExitLabel">Close form</h5>
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close" title="Close" data-bs-toggle="tooltip">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
            </div>
            <div class="modal-body">
                <p class="mb-0">
                    Do you want to save your changes before closing, or close and discard them?
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" id="btn-exit-save-and-close" title="Save and close" data-bs-toggle="tooltip">
                    Save and close
                </button>
                <button type="button" class="btn btn-warning" id="btn-exit-discard-and-close" title="Discard and close" data-bs-toggle="tooltip">
                    Discard and close
                </button>
                <button type="button" class="btn btn-light" data-bs-dismiss="modal" title="Cancel" data-bs-toggle="tooltip">Cancel</button>
            </div>
        </div>
    </div>
</div>

