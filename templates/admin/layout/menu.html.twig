                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Vendors</span>
                        </a>
                     </div>
                     {% endif %}
                  </div>
               </div>
               {% endif %}

               {% if menu.menuOverhead or menu.menuMaterial %}
               <div
                  data-kt-menu-trigger="click"
                  class="menu-item menu-accordion
                     {{ activeRoute == 'overheadprice' or activeRoute == 'material' ? 'here show' }}"
               >
                  <span class="menu-link">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-abstract-26 fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Libraries</span>
                     <span class="menu-arrow"></span>
                  </span>
                  <div class="menu-sub menu-sub-accordion">
                     {% if menu.menuOverhead %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'overheadprice' ? 'active' }}" href="{{ url('overheadprice') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Overhead Price</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuMaterial %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'material' ? 'active' }}" href="{{ url('material') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Materials</span>
                        </a>
                     </div>
                     {% endif %}
                  </div>
               </div>
               {% endif %}

               {% endif %}
               <!-- end 4. ACCOUNTING -->

               <!-- 5. HR -->
               {% if menu.menuEmployeeRrhh or (menu.menuCertifiedPayroll is defined and menu.menuCertifiedPayroll) or
                     menu.menuReporteEmployee or menu.menuRace or menu.menuEmployee or
                     menu.menuEmployeeRole or (menu.menuCrew is defined and menu.menuCrew) %}

               <div class="menu-item pt-5">
                  <div class="menu-content">
                     <span class="menu-heading fw-bold text-uppercase fs-7">HR</span>
                  </div>
               </div>

               {% if menu.menuEmployeeRrhh %}
               <div class="menu-item">
                  <a class="menu-link {{ activeRoute == 'employees-rrhh' ? 'active' }}" href="{{ url('employee_rrhh') }}">
