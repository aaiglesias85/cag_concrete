                  data-kt-menu-trigger="click"
                  class="menu-item menu-accordion
                     {{ activeRoute == 'reporte_subcontractor' or activeRoute == 'conc_vendor' ? 'here show' }}"
               >
                  <span class="menu-link">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-dollar fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Accounts Payable</span>
                     <span class="menu-arrow"></span>
                  </span>
                  <div class="menu-sub menu-sub-accordion">
                     {% if menu.menuReporteSubcontractor %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'reporte_subcontractor' ? 'active' }}" href="{{ url('reporte_subcontractor') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Subcontractors' Report</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuConcreteVendor %}
