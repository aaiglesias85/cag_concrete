<div
   id="kt_app_sidebar"
   class="app-sidebar flex-column"
   data-kt-drawer="true"
   data-kt-drawer-name="app-sidebar"
   data-kt-drawer-activate="{default: true, lg: false}"
   data-kt-drawer-overlay="true"
   data-kt-drawer-width="225px"
   data-kt-drawer-direction="start"
   data-kt-drawer-toggle="#kt_app_sidebar_mobile_toggle"
>
   <!--begin::Logo-->
   <div class="app-sidebar-logo px-6" id="kt_app_sidebar_logo">
      <a href="{{ url('home') }}">
         <img alt="Logo" src="{{ asset('bundles/metronic8/img/logo_blanco.png') }}" class="h-75px app-sidebar-logo-default" />
         <img alt="Logo" src="{{ asset('bundles/metronic8/img/logo_blanco.png') }}" class="h-40px app-sidebar-logo-minimize" />
      </a>
      <div
         id="kt_app_sidebar_toggle"
         class="app-sidebar-toggle btn btn-icon btn-shadow btn-sm btn-color-muted btn-active-color-primary h-30px w-30px position-absolute top-50 start-100 translate-middle rotate"
         data-kt-toggle="true"
         data-kt-toggle-state="active"
         data-kt-toggle-target="body"
         data-kt-toggle-name="app-sidebar-minimize"
      >
         <i class="ki-duotone ki-black-left-line fs-3 rotate-180">
            <span class="path1"></span>
            <span class="path2"></span>
         </i>
      </div>
   </div>
   <!--end::Logo-->

   <!--begin::sidebar menu-->
   <div class="app-sidebar-menu overflow-hidden flex-column-fluid">
      <div id="kt_app_sidebar_menu_wrapper" class="app-sidebar-wrapper">
         <div
            id="kt_app_sidebar_menu_scroll"
            class="scroll-y my-5 mx-3"
            data-kt-scroll="true"
            data-kt-scroll-activate="true"
            data-kt-scroll-height="auto"
            data-kt-scroll-dependencies="#kt_app_sidebar_logo, #kt_app_sidebar_footer"
            data-kt-scroll-wrappers="#kt_app_sidebar_menu"
            data-kt-scroll-offset="5px"
            data-kt-scroll-save-state="true"
         >
            <div class="menu menu-column menu-rounded menu-sub-indention fw-semibold fs-6" id="#kt_app_sidebar_menu" data-kt-menu="true" data-kt-menu-expand="false">

               <!-- 0. HOME -->
               {% if menu.menuInicio %}
               <div class="menu-item">
                  <a class="menu-link {{ activeRoute == 'home' ? 'active' }}" href="{{ url('home') }}">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-element-11 fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                           <span class="path3"></span>
                           <span class="path4"></span>
                        </i>
                     </span>
                     <span class="menu-title">Home</span>
                  </a>
               </div>
               {% endif %}

               <!-- 1. ESTIMATING -->
               {% if menu.menuEstimate or menu.menuItem or menu.menuEquation or
                     menu.menuUnit or menu.menuProjectStage or menu.menuProjectType or
                     menu.menuProposalType or menu.menuPlanStatus or menu.menuPlanDownloading or
                     menu.menuDistrict or menu.menuCounty or menu.menuEstimateNoteItem %}

               <div class="menu-item pt-5">
                  <div class="menu-content">
                     <span class="menu-heading fw-bold text-uppercase fs-7">Estimating</span>
                  </div>
               </div>

               {% if menu.menuEstimate %}
               <div class="menu-item">
                  <a class="menu-link {{ activeRoute == 'estimate' ? 'active' }}" href="{{ url('estimate') }}">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-abstract-25 fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Project Estimates</span>
                  </a>
               </div>
               {% endif %}

               {% if menu.menuItem or menu.menuEquation or menu.menuUnit or menu.menuProjectStage or
                     menu.menuProjectType or menu.menuProposalType or menu.menuPlanStatus or
                     menu.menuPlanDownloading or menu.menuDistrict or menu.menuCounty or
                     menu.menuEstimateNoteItem %}
               <div
                  data-kt-menu-trigger="click"
                  class="menu-item menu-accordion
                     {{ activeRoute == 'item' or activeRoute == 'equation' or activeRoute == 'unit' or
                        activeRoute == 'project_stage' or activeRoute == 'project_type' or
                        activeRoute == 'proposal_type' or activeRoute == 'plan_status' or
                        activeRoute == 'plan_downloading' or activeRoute == 'district' or
                        activeRoute == 'county' or activeRoute == 'estimate_note_item' ? 'here show' }}"
               >
                  <span class="menu-link">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-abstract-26 fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Libraries</span>
                     <span class="menu-arrow"></span>
                  </span>
                  <div class="menu-sub menu-sub-accordion">
                     {% if menu.menuItem %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'item' ? 'active' }}" href="{{ url('item') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Items</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuEquation %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'equation' ? 'active' }}" href="{{ url('equation') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Equations</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuUnit %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'unit' ? 'active' }}" href="{{ url('unit') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Unit of Measurement</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuProjectStage %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'project_stage' ? 'active' }}" href="{{ url('project_stage') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Project Stages</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuProjectType %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'project_type' ? 'active' }}" href="{{ url('project_type') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Project Types</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuProposalType %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'proposal_type' ? 'active' }}" href="{{ url('proposal_type') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Proposal Types</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuPlanStatus %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'plan_status' ? 'active' }}" href="{{ url('plan_status') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Plan Status</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuPlanDownloading %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'plan_downloading' ? 'active' }}" href="{{ url('plan_downloading') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Plan Downloading</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuDistrict %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'district' ? 'active' }}" href="{{ url('district') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Districts</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuCounty %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'county' ? 'active' }}" href="{{ url('county') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Locations</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuEstimateNoteItem %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'estimate_note_item' ? 'active' }}" href="{{ url('estimate_note_item') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Notes</span>
                        </a>
                     </div>
                     {% endif %}
                  </div>
               </div>
               {% endif %}

               {% endif %}
               <!-- end 1. ESTIMATING -->

               <!-- 2. PROJECT ONBOARDING -->
               {% if menu.menuContract ?? false or menu.menuCompany or menu.menuProject or menu.menuSubcontractor or menu.menuConcreteClass %}

               <div class="menu-item pt-5">
                  <div class="menu-content">
                     <span class="menu-heading fw-bold text-uppercase fs-7">Project Onboarding</span>
                  </div>
               </div>

               {% if menu.menuContract ?? false %}
               <div class="menu-item">
                  <a class="menu-link {{ activeRoute == 'contract' ? 'active' }}" href="{{ url('contract') }}">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-file-added fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Contracts</span>
                  </a>
               </div>
               {% endif %}

               {% if menu.menuCompany %}
               <div class="menu-item">
                  <a class="menu-link {{ activeRoute == 'company' ? 'active' }}" href="{{ url('company') }}">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-briefcase fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Companies</span>
                  </a>
               </div>
               {% endif %}

               {% if menu.menuProject %}
               <div class="menu-item">
                  <a class="menu-link {{ activeRoute == 'project' ? 'active' }}" href="{{ url('project') }}">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-abstract-41 fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Projects</span>
                  </a>
               </div>
               {% endif %}

               {% if menu.menuSubcontractor %}
               <div class="menu-item">
                  <a class="menu-link {{ activeRoute == 'subcontractor' ? 'active' }}" href="{{ url('subcontractor') }}">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-people fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                           <span class="path3"></span>
                           <span class="path4"></span>
                           <span class="path5"></span>
                        </i>
                     </span>
                     <span class="menu-title">Subcontractors</span>
                  </a>
               </div>
               {% endif %}

               {% if menu.menuConcreteClass %}
               <div
                  data-kt-menu-trigger="click"
                  class="menu-item menu-accordion {{ activeRoute == 'concrete_class' ? 'here show' }}"
               >
                  <span class="menu-link">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-abstract-26 fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Libraries</span>
                     <span class="menu-arrow"></span>
                  </span>
                  <div class="menu-sub menu-sub-accordion">
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'concrete_class' ? 'active' }}" href="{{ url('concrete_class') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Concrete Classes</span>
                        </a>
                     </div>
                  </div>
               </div>
               {% endif %}

               {% endif %}
               <!-- end 2. PROJECT ONBOARDING -->

               <!-- 3. PROJECT MANAGEMENT -->
               {% if menu.menuSchedule or menu.menuDataTracking or menu.menuInspector or menu.menuHoliday %}

               <div class="menu-item pt-5">
                  <div class="menu-content">
                     <span class="menu-heading fw-bold text-uppercase fs-7">Project Management</span>
                  </div>
               </div>

               {% if menu.menuSchedule %}
               <div class="menu-item">
                  <a class="menu-link {{ activeRoute == 'schedule' ? 'active' }}" href="{{ url('schedule') }}">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-calendar-8 fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                           <span class="path3"></span>
                           <span class="path4"></span>
                           <span class="path5"></span>
                           <span class="path6"></span>
                        </i>
                     </span>
                     <span class="menu-title">Schedule</span>
                  </a>
               </div>
               {% endif %}

               {% if menu.menuDataTracking %}
               <div class="menu-item">
                  <a class="menu-link {{ activeRoute == 'data_tracking' ? 'active' }}" href="{{ url('data_tracking') }}">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-design-frame fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Data Tracking</span>
                  </a>
               </div>
               {% endif %}

               {% if menu.menuInspector or menu.menuHoliday %}
               <div
                  data-kt-menu-trigger="click"
                  class="menu-item menu-accordion
                     {{ activeRoute == 'inspectors' or activeRoute == 'holiday' ? 'here show' }}"
               >
                  <span class="menu-link">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-abstract-26 fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Libraries</span>
                     <span class="menu-arrow"></span>
                  </span>
                  <div class="menu-sub menu-sub-accordion">
                     {% if menu.menuInspector %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'inspectors' ? 'active' }}" href="{{ url('inspectors') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Inspectors</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuHoliday %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'holiday' ? 'active' }}" href="{{ url('holiday') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Holidays</span>
                        </a>
                     </div>
                     {% endif %}
                  </div>
               </div>
               {% endif %}

               {% endif %}
               <!-- end 3. PROJECT MANAGEMENT -->

               <!-- 4. ACCOUNTING -->
               {% if menu.menuInvoice or menu.menuPayment or menu.menuOverridePayment or
                     menu.menuReporteSubcontractor or menu.menuConcreteVendor or
                     menu.menuOverhead or menu.menuMaterial %}

               <div class="menu-item pt-5">
                  <div class="menu-content">
                     <span class="menu-heading fw-bold text-uppercase fs-7">Accounting</span>
                  </div>
               </div>

               {% if menu.menuInvoice or menu.menuPayment or menu.menuOverridePayment %}
               <div
                  data-kt-menu-trigger="click"
                  class="menu-item menu-accordion
                     {{ activeRoute == 'invoice' or activeRoute == 'payment' or activeRoute == 'override_payment' ? 'here show' }}"
               >
                  <span class="menu-link">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-bank fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                        </i>
                     </span>
                     <span class="menu-title">Accounts Receivable</span>
                     <span class="menu-arrow"></span>
                  </span>
                  <div class="menu-sub menu-sub-accordion">
                     {% if menu.menuInvoice %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'invoice' ? 'active' }}" href="{{ url('invoice') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Invoices</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuPayment %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'payment' ? 'active' }}" href="{{ url('payment') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Payments</span>
