                     {% endif %}
                     {% if menu.menuEmployee %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'employee' ? 'active' }}" href="{{ url('employee') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Employees</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuEmployeeRole %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'employee_role' ? 'active' }}" href="{{ url('employee_role') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Employee Roles</span>
                        </a>
                     </div>
                     {% endif %}
                     {% if menu.menuCrew is defined and menu.menuCrew %}
