                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'race' ? 'active' }}" href="{{ url('race') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
                           <span class="menu-title">Ethnicity / Race</span>
