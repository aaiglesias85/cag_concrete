                        <i class="ki-duotone ki-address-book fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                           <span class="path3"></span>
                        </i>
                     </span>
                     <span class="menu-title">Employees</span>
                  </a>
               </div>
               {% endif %}

               {% if (menu.menuCertifiedPayroll is defined and menu.menuCertifiedPayroll) or menu.menuReporteEmployee %}
               <div
                  data-kt-menu-trigger="click"
                  class="menu-item menu-accordion
                     {{ activeRoute == 'certified_payroll' or activeRoute == 'reporte_employee' ? 'here show' }}"
               >
                  <span class="menu-link">
                     <span class="menu-icon">
                        <i class="ki-duotone ki-book-open fs-2">
                           <span class="path1"></span>
                           <span class="path2"></span>
                           <span class="path3"></span>
                           <span class="path4"></span>
                        </i>
                     </span>
                     <span class="menu-title">Reports</span>
                     <span class="menu-arrow"></span>
                  </span>
                  <div class="menu-sub menu-sub-accordion">
                     {% if menu.menuCertifiedPayroll is defined and menu.menuCertifiedPayroll %}
                     <div class="menu-item">
                        <a class="menu-link {{ activeRoute == 'certified_payroll' ? 'active' }}" href="{{ url('certified_payroll') }}">
                           <span class="menu-bullet"><span class="bullet bullet-dot"></span></span>
