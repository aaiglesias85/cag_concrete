{# Permission matrix grouped by sidebar modules (Bootstrap accordion). #}
<div class="accordion permisos-modulos-accordion" id="accordionPermisosModulos">
   {% for grupo in funcionesAgrupadas %}
      <div class="accordion-item border border-gray-300 rounded mb-2 overflow-hidden">
         <h2 class="accordion-header perm-accordion-module-header mb-0" id="heading-{{ grupo.grupoId }}" style="background-color:#f1f3f4;">
            <button
               class="accordion-button fw-bold shadow-none py-3"
               type="button"
               data-bs-toggle="collapse"
               data-bs-target="#{{ grupo.grupoId }}"
               aria-expanded="true"
               aria-controls="{{ grupo.grupoId }}"
               style="background-color:#f1f3f4;"
            >
               {{ grupo.titulo }}
            </button>
         </h2>
         <div id="{{ grupo.grupoId }}" class="accordion-collapse collapse show" aria-labelledby="heading-{{ grupo.grupoId }}">
            <div class="accordion-body p-0">
               <div class="table-responsive">
                  <table class="table table-striped table-row-bordered align-middle gs-0 gy-2 mb-0">
                     <thead>
                        <tr class="fw-bold fs-7 text-gray-800 text-uppercase">
                           <th class="min-w-200px border-end-0" style="padding-left:20px;" scope="col"></th>
                           <th class="text-center w-100px" scope="col">View</th>
                           <th class="text-center w-100px" scope="col">Add</th>
                           <th class="text-center w-100px" scope="col">Edit</th>
                           <th class="text-center w-100px" scope="col">Delete</th>
                           <th class="text-center w-100px" scope="col">All</th>
                        </tr>
                     </thead>
                     <tbody>
                        {% for item in grupo.funciones %}
                           <tr class="tr-permiso" data-id="{{ item.funcionId }}">
                              <td style="padding-left:20px;">{{ item.descripcion }}</td>
                              <td class="text-center w-100px">
                                 <div class="form-check form-check-sm form-check-custom form-check-solid d-inline-block">
                                    <input class="form-check-input checkbox-permiso checkbox-permiso-ver" type="checkbox" data-id="{{ item.funcionId }}" />
                                 </div>
                              </td>
                              <td class="text-center w-100px">
                                 <div class="form-check form-check-sm form-check-custom form-check-solid d-inline-block">
                                    <input class="form-check-input checkbox-permiso checkbox-permiso-agregar" type="checkbox" data-id="{{ item.funcionId }}" />
                                 </div>
                              </td>
                              <td class="text-center w-100px">
                                 <div class="form-check form-check-sm form-check-custom form-check-solid d-inline-block">
                                    <input class="form-check-input checkbox-permiso checkbox-permiso-editar" type="checkbox" data-id="{{ item.funcionId }}" />
                                 </div>
                              </td>
                              <td class="text-center w-100px">
                                 <div class="form-check form-check-sm form-check-custom form-check-solid d-inline-block">
                                    <input class="form-check-input checkbox-permiso checkbox-permiso-eliminar" type="checkbox" data-id="{{ item.funcionId }}" />
                                 </div>
                              </td>
                              <td class="text-center w-100px">
                                 <div class="form-check form-check-sm form-check-custom form-check-solid d-inline-block">
                                    <input class="form-check-input checkbox-permiso checkbox-permiso-todos" type="checkbox" data-id="{{ item.funcionId }}" />
                                 </div>
                              </td>
                           </tr>
                        {% endfor %}
                     </tbody>
                  </table>
               </div>
            </div>
         </div>
      </div>
   {% endfor %}
</div>
